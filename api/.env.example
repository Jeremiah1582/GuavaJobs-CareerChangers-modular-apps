# Core
NODE_ENV=development
PORT=3000

# ─── Supabase Postgres (primary) ─────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL — Session pooler (IPv4). Use for the running API at runtime.
#   Host: aws-0-<region>.pooler.supabase.com  Port: 5432  User: postgres.<project-ref>
#
# DIRECT_URL — Direct connection. REQUIRED for prisma migrate / reset.
#   Host: db.<project-ref>.supabase.co  Port: 5432  User: postgres
#
# If migrate fails with P1000: reset the database password in Supabase and update both URLs.
# If drift / old schema: npx prisma migrate reset --force  (destroys all data in public schema)
#
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# Redis — local Docker for Phase 0 job cache / BullMQ (npm run dev:infra starts redis only)
REDIS_URL="redis://localhost:6379"

# Supabase Auth + Storage (same project as DATABASE_URL)
SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
SUPABASE_ANON_KEY=""              # or SUPABASE_PUBLISHABLE_KEY — match your Supabase dashboard naming
SUPABASE_SERVICE_ROLE_KEY=""      # must be from the SAME project ref as SUPABASE_URL
SUPABASE_JWT_SECRET=""            # Project Settings → API → JWT Secret (legacy) OR use JWKS URL below
SUPABASE_JWKS_URL=""              # https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET="cvs"

# OpenAI-compatible LLM (use OPENAI_API_KEY — OpenRouter keys sk-or-* are auto-routed)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"          # OpenAI models; ignored for sk-or-* keys

# Optional explicit OpenRouter model when OPENAI_API_KEY is an OpenRouter key
# OPENROUTER_MODEL="deepseek/deepseek-chat"

# Optional local dev flags
DEV_MODE="True"                   # True | False — reserved for future dev-only behavior

# BullMQ workers — on by default (API + processors run together in one Coolify container).
# Set false only if processors are split into a separate deployment.
# RUN_BULLMQ_WORKERS="false"

# Optional seed (must match Supabase Auth user UUID if set)
# SEED_USER_ID=""
# SEED_USER_EMAIL=""
# SEED_USER_NAME=""

# Adzuna
ADZUNA_APP_ID=""
ADZUNA_API_KEY=""                  # or ADZUNA_APP_KEY
ADZUNA_DEFAULT_COUNTRY="gb"

# ─── Optional: local Postgres (not used when Supabase is primary) ────────────
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guavajobs?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/guavajobs?schema=public"

QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
