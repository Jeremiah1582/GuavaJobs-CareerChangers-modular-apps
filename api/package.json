{
  "name": "@guavajobs/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "npx nest build",
    "dev": "npm run dev:infra && nest start --watch",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "dev:infra": "docker compose up -d redis --remove-orphans",
    "db:validate": "prisma validate",
    "db:reset": "prisma migrate reset",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.config.js --runInBand",
    "test:e2e:money": "REDIS_URL=${E2E_REDIS_URL:-redis://127.0.0.1:6379} jest --config ./test/jest-e2e.config.js --runInBand --testPathPattern='(generate|manual|quota)\\.e2e-spec'",
    "test:smoke": "node scripts/endpoint-smoke-test.mjs",
    "jobs:search": "node scripts/job-search.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.9.0",
    "@types/multer": "^2.2.0",
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1",
    "jose": "^5.10.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.0"
  }
}
